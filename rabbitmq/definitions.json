  "users": [
    {
      "name": "admin",
      "password_hash": "7Em3lKIvIWBZfeUlOpodIiqyw5glulFA1AHmVFMVI0bTUrXp",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": "administrator"
    },
    {
      "name": "task-scheduler",
      "password_hash": "NUC4MX1rjT4GK20jvMjXR5503k7HIuj7612TbAg6zMtYHiur",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ""
    },
    {
      "name": "notifier",
      "password_hash": "w7MDTKORjjUz7M32F0XZZZc4zBb+W8PYeYgX/euUTSaVFJBz",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ""
    }
  ],

  "permissions": [
    {
      "user": "admin",
      "vhost": "ts-system",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "task-scheduler",
      "vhost": "ts-system",
      "configure": "^$",
      "write": "^notification\\.exchange$",
      "read": "^notification\\.(completed|failed)\\.queue$"
    },
    {
      "user": "notifier",
      "vhost": "ts-system",
      "configure": "^$",
      "write": "^notification\\.exchange$",
      "read": "^notification\\.request\\.queue$"
    }
  ],

  "exchanges": [
    {
      "name": "notification.exchange",
      "vhost": "ts-system",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],

  "queues": [
    {
      "name": "notification.request.queue",
      "vhost": "ts-system",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "notification.completed.queue",
      "vhost": "ts-system",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "notification.failed.queue",
      "vhost": "ts-system",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],

  "bindings": [
    {
      "vhost": "ts-system",
      "source": "notification.exchange",
      "destination": "notification.request.queue",
      "destination_type": "queue",
      "routing_key": "notification.request",
      "arguments": {}
    },
    {
      "vhost": "ts-system",
      "source": "notification.exchange",
      "destination": "notification.completed.queue",
      "destination_type": "queue",
      "routing_key": "notification.completed",
      "arguments": {}
    },
    {
      "vhost": "ts-system",
      "source": "notification.exchange",
      "destination": "notification.failed.queue",
      "destination_type": "queue",
      "routing_key": "notification.failed",
      "arguments": {}
    }
  ]
}